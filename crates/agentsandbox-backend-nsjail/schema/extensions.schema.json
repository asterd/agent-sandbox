{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "nsjail Backend Extensions",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nsjail": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "seccompPolicy": { "type": "string" },
        "rlimitNofile": { "type": "integer" },
        "rlimitNproc": { "type": "integer" },
        "bindmountRo": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cgroupMemMax": { "type": "integer" }
      }
    }
  }
}
